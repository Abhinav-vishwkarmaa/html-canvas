# Copy to deploy.env and fill in your server values:
#   cp deploy.env.example deploy.env
#
# deploy.sh reads this file. It is gitignored — never commit secrets.
#
# Domain nahi — sirf IP + port se access:
#   Frontend: http://SERVER_HOST:FRONTEND_PORT
#   Backend:  http://SERVER_HOST:BACKEND_PORT/api

# --- Server IP (jo browser me type karoge — wahi likho) ---
SERVER_HOST=103.131.24.113
BACKEND_PORT=3000
FRONTEND_PORT=8080

# Optional: pull latest code before deploy (git repo must exist on server)
DEPLOY_GIT_PULL=false
DEPLOY_GIT_BRANCH=main

# --- Backend .env overrides (external MySQL — not in Docker) ---
DB_HOST=your-mysql-host
DB_PORT=3306
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_DATABASE=template_builder

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRATION=24h

# Elasticsearch runs via Docker on this same server
ELASTICSEARCH_NODE=http://127.0.0.1:9200
ELASTICSEARCH_INDEX=campaign_events

# Optional: S3 / Cloudinary (leave blank if using local uploads)
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_CLOUDFRONT_URL=
