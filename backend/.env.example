# Server
PORT=3000
NODE_ENV=production

# External MySQL (Docker me nahi)
DB_HOST=your-mysql-host
DB_PORT=3306
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_DATABASE=template_builder

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRATION=24h

# Production frontend URL (comma-separated for multiple origins)
CORS_ORIGIN=http://103.131.24.113:8080

# Elasticsearch (Docker: docker compose up -d elasticsearch)
ELASTICSEARCH_NODE=http://127.0.0.1:9200
ELASTICSEARCH_INDEX=campaign_events

# Optional uploads
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_CLOUDFRONT_URL=
